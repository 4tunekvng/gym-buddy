# Gym Buddy — local environment template.
#
# Copy this file to `.env` (which is gitignored) and fill in your values.
# `scripts/run-simulator.sh` sources `.env` and forwards these vars into the
# launched app, so the app sees them via ProcessInfo.processInfo.environment.
#
# AppRuntime.swift checks the GYMBUDDY_-prefixed name first, then the bare
# name, then Info.plist — so either form works. Use whichever you prefer.

# Live Anthropic (Claude) backend for post-set summaries, between-set Q&A,
# memory extraction, etc. WITHOUT this set, the app falls back to a
# deterministic grounded summary that still references the rep count, but
# it won't be the real conversational LLM experience.
ANTHROPIC_API_KEY=

# Force the deterministic scripted-pose path (default: auto — try camera, fall
# back to scripted if permission denied / camera unavailable).
# Useful when you want a reproducible demo loop in the simulator.
# GYMBUDDY_POSE_MODE=demo

# Force mock LLM (skip Anthropic entirely, even if a key is set).
# GYMBUDDY_LLM_MODE=mock

# Force silent mock voice (no audio, useful for CI / debugging).
# GYMBUDDY_VOICE_MODE=mock

# Speed up the scripted-demo pose stream by N× (default 1.0). UI tests use 3.0.
# GYMBUDDY_SCRIPTED_DEMO_PLAYBACK_RATE=1.0

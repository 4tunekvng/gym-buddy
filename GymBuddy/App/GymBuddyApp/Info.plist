<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>ANTHROPIC_API_KEY</key>
	<string></string>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>GYMBUDDY_LLM_MODE</key>
	<string>auto</string>
	<key>GYMBUDDY_POSE_MODE</key>
	<string>auto</string>
	<key>GYMBUDDY_SCRIPTED_DEMO_PLAYBACK_RATE</key>
	<string>1.0</string>
	<key>GYMBUDDY_VOICE_MODE</key>
	<string>system</string>
	<key>NSCameraUsageDescription</key>
	<string>Gym Buddy uses the camera to count reps, watch form, and show live setup feedback during coached sets. Frames stay on this device — they're never uploaded.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Gym Buddy reads HRV and sleep from Health to suggest today's load — read-only, never written back.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Gym Buddy uses your microphone for between-set conversation and to listen for pain signals during a set.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Gym Buddy transcribes your between-set questions on-device when supported.</string>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string></string>
	</dict>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
